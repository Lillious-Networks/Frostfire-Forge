# Development Dockerfile for Frostfire Forge Game Server
# Requires Frostfire Forge Gateway to be running before starting this container
FROM oven/bun:canary AS base
WORKDIR /app

# Copy .env file stage
FROM base AS envcopy
WORKDIR /app
# Copy if exists otherwise create during build
COPY .env.development .env.development

# Install dependencies stage
FROM base AS deps
COPY package.json bun.lockb* ./
RUN bun install --frozen-lockfile

# Build stage
FROM base AS build
COPY package.json bun.lockb* ./
RUN bun install --frozen-lockfile
COPY . .

# Development stage
FROM base AS development
WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app .
COPY --from=envcopy /app/.env.development .env.development

RUN bun create-config --environment development
RUN bun setup-development

# Expose WebSocket port only (no webserver)
EXPOSE 3000

# Health check - verify WebSocket server is running
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD bun -e "fetch('http://localhost:3000').then(r => process.exit(0)).catch(() => process.exit(1))"

# Start game server - first initialize database, then start server
CMD ["sh", "-c", "bun --env-file=.env.development ./src/utility/database_setup.ts && bun run development"]
