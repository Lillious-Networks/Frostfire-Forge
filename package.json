{
  "name": "frostfire-forge",
  "module": "./src/socket/server.ts",
  "dependencies": {
    "openai": "^4.104.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.9",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^22.19.11",
    "chalk": "^5.6.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.55.0"
  },
  "scripts": {
    "production": "bun create-config --environment production && bun --env-file=.env.production ./src/socket/server.ts --sql-preconnect",
    "development": "bun create-config --environment development && bun --env-file=.env.development ./src/socket/server.ts",
    "setup": "bun --env-file=.env.production ./src/utility/database_setup.ts",
    "create-config": "bun ./src/utility/create_config.ts",
    "setup-development": "bun create-config --environment development",
    "setup-production": "bun create-config --environment production && bun setup",
    "setup-localdb": "bun --env-file=.env.development ./src/utility/database_setup_sqlite.ts",
    "docker:dev": "docker compose -f src/docker/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f src/docker/docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f src/docker/docker-compose.dev.yml logs -f",
    "docker:dev:build": "docker compose -f src/docker/docker-compose.dev.yml build",
    "docker:dev:rebuild": "docker compose -f src/docker/docker-compose.dev.yml up -d --build --force-recreate",
    "docker:prod": "docker compose -f src/docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f src/docker/docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f src/docker/docker-compose.prod.yml logs -f",
    "docker:prod:build": "docker compose -f src/docker/docker-compose.prod.yml build",
    "docker:prod:rebuild": "docker compose -f src/docker/docker-compose.prod.yml up -d --build --force-recreate",
    "benchmark": "bun ./src/utility/benchmark-cli.ts",
    "benchmark:development": "bun --env-file=.env.development ./src/utility/benchmark-cli.ts",
    "benchmark:production": "bun --env-file=.env.production ./src/utility/benchmark-cli.ts",
    "benchmark:connections": "bun ./src/utility/benchmark-connections.ts",
    "benchmark:connections:development": "bun --env-file=.env.development ./src/utility/benchmark-connections.ts",
    "benchmark:connections:production": "bun --env-file=.env.production ./src/utility/benchmark-connections.ts"
  },
  "type": "module"
}
